# Telegram API credentials
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH="abcdef1234567890abcdef1234567890"
TELEGRAM_PHONE=+918765432109

# OpenAI API key
OPENAI_API_KEY="sk-proj-example1234567890abcdef1234567890abcdef1234567890abcdef1234567890"


# Office location (latitude, longitude)
OFFICE_LATITUDE=24.12345678901234
OFFICE_LONGITUDE=71.64319307573706
OFFICE_ADDRESS="123 Example Street, Example City, State, 123456"

# Target channel/chat for house hunting
TARGET_CHAT=@channelname_or_chat_id
TARGET_PEER_ID=1234567890

# Google Maps API Key
GOOGLE_MAPS_API_KEY="abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890"
WHATSAPP_TARGET_CHAT="Example WhatsApp Group"

# --- LLM Provider & Model Settings ---
# MODEL_PROVIDER can be 'openai' or 'gemini'
MODEL_PROVIDER=openai
# MODEL_NAME can be any OpenAI model (e.g. gpt-4.1, gpt-5.4, gpt-4o-mini) or Gemini model (e.g. gemini-2.5-flash)
MODEL_NAME=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key